parameters:
    level: max
    paths:
        - src
        - tests
    reportUnmatchedIgnoredErrors: true
    ignoreErrors:
        # unpack() is typed as array|false with mixed values; the 'N' format guarantees an integer at the offset.
        - identifier: offsetAccess.nonOffsetAccessible
          path: src/Internal/Timestamp.php
        - identifier: argument.type
          path: src/Internal/Timestamp.php
        # Data providers and array-shaped test inputs carry no value type. Tests route through ignoreErrors, not PHPDoc.
        - identifier: missingType.iterableValue
          path: tests/KsuidTest.php
